# Streamlit Cloud secrets — copy this file to .streamlit/secrets.toml
# and fill in your real values. NEVER commit secrets.toml to git.
#
# In Streamlit Cloud, add these via:
#   App settings → Secrets → paste contents below

# Required for AI explanations (app works without it — explanations disabled)
ANTHROPIC_API_KEY = "sk-ant-your-key-here"

# Only needed if the HuggingFace dataset repo is private
# Leave empty or omit for public repos
HF_TOKEN = "hf_your-token-here"
